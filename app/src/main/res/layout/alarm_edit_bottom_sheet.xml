<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:paddingTop="16dp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.best.deskclock.uicomponents.TextTime
                android:id="@+id/digital_clock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:paddingHorizontal="10dp"
                android:gravity="center"
                android:textSize="48sp"
                android:textStyle="bold"
                android:focusable="true"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="08:30" />

            <!-- Day buttons are added programmatically -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                style="@style/Widget.Material3.MaterialButtonGroup.Connected"
                android:id="@+id/repeat_days_group"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="10dp"
                android:gravity="center"
                app:singleSelection="false"
                app:layout_constraintTop_toBottomOf="@id/digital_clock" />

            <LinearLayout
                android:id="@+id/schedule_alarm_layout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/repeat_days_group">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/schedule_alarm"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:paddingHorizontal="10dp"
                    android:focusable="true"
                    android:drawableStart="@drawable/ic_calendar_clock"
                    android:drawablePadding="10dp"
                    android:gravity="center_vertical"
                    android:maxLines="2"
                    android:ellipsize="end"
                    tools:text="@string/schedule_alarm_title" />

                <com.google.android.material.button.MaterialButton
                    style="?attr/materialButtonOutlinedStyle"
                    android:id="@+id/cancel_scheduled_alarm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:layout_gravity="center"
                    android:paddingStart="8dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:text="@android:string/cancel"
                    android:textColor="?android:attr/textColorPrimary"
                    android:includeFontPadding="false"
                    android:visibility="gone"
                    app:icon="@drawable/ic_calendar_cancel"
                    app:strokeColor="?attr/colorOnSurfaceVariant"
                    tools:visibility="gone" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/pause_alarm_layout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@id/schedule_alarm_layout">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/pause_alarm"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:paddingHorizontal="10dp"
                    android:drawableStart="@drawable/ic_alarm_pause"
                    android:drawablePadding="10dp"
                    android:gravity="center_vertical"
                    android:focusable="true"
                    android:ellipsize="end"
                    android:maxLines="2"
                    tools:text="Paused May 10 - Jun 10" />

                <com.google.android.material.button.MaterialButton
                    style="?attr/materialButtonOutlinedStyle"
                    android:id="@+id/pause_alarm_cancel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:layout_gravity="center"
                    android:paddingStart="8dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:text="@android:string/cancel"
                    android:textColor="?android:attr/textColorPrimary"
                    android:includeFontPadding="false"
                    android:visibility="gone"
                    app:icon="@drawable/ic_cancel"
                    app:iconTint="?attr/colorOnSurfaceVariant"
                    app:strokeColor="?attr/colorOnSurfaceVariant"
                    tools:visibility="visible" />

            </LinearLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/edit_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="10dp"
                android:minHeight="48dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="10dp"
                android:drawableStart="@drawable/ic_label"
                android:drawablePadding="10dp"
                android:drawableTint="?attr/colorOnSurfaceVariant"
                android:gravity="center_vertical"
                android:focusable="true"
                android:text="@string/add_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/pause_alarm_layout" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/choose_ringtone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="2dp"
                android:paddingHorizontal="10dp"
                android:drawableStart="@drawable/ic_ringtone"
                android:drawablePadding="10dp"
                android:drawableTint="?attr/colorOnSurfaceVariant"
                android:gravity="center_vertical"
                android:focusable="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:scrollHorizontally="true"
                android:singleLine="true"
                app:layout_constraintTop_toBottomOf="@id/edit_label"
                tools:text="Standard (Hassium)" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/vibrate_onoff"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="10dp"
                android:button="@null"
                android:drawableStart="@drawable/ic_vibrate"
                android:drawableEnd="@drawable/ic_selector_checkbox"
                android:drawablePadding="10dp"
                android:text="@string/alarm_vibrate"
                app:layout_constraintTop_toBottomOf="@id/choose_ringtone"
                tools:ignore="RtlSymmetry"
                tools:checked="true" />

            <LinearLayout
                android:id="@+id/vibration_pattern_layout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="2dp"
                android:paddingHorizontal="10dp"
                app:layout_constraintTop_toBottomOf="@id/vibrate_onoff">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/vibration_pattern_title"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_earthquake"
                    android:paddingStart="@null"
                    android:paddingEnd="10dp"
                    android:drawablePadding="10dp"
                    android:drawableTint="?attr/colorOnSurfaceVariant"
                    android:gravity="center_vertical"
                    android:focusable="true"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="@string/vibration_pattern_title" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/vibration_pattern_value"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:focusable="true"
                    android:maxLines="1"
                    tools:text="Strong" />

            </LinearLayout>

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/flash_onoff"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="2dp"
                android:paddingHorizontal="10dp"
                android:button="@null"
                android:drawableStart="@drawable/ic_flash"
                android:drawableEnd="@drawable/ic_selector_checkbox"
                android:drawablePadding="10dp"
                android:text="@string/alarm_flash"
                app:layout_constraintTop_toBottomOf="@id/vibration_pattern_layout"
                tools:ignore="RtlSymmetry"
                tools:checked="false" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/delete_occasional_alarm_after_use"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="2dp"
                android:paddingHorizontal="10dp"
                android:button="@null"
                android:drawableStart="@drawable/ic_clear"
                android:drawableEnd="@drawable/ic_selector_checkbox"
                android:drawablePadding="10dp"
                android:text="@string/delete_occasional_alarm_after_use_title"
                app:layout_constraintTop_toBottomOf="@id/flash_onoff"
                app:layout_goneMarginTop="10dp"
                tools:ignore="RtlSymmetry"
                tools:checked="true" />

            <Space
                android:id="@+id/space"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                app:layout_constraintTop_toBottomOf="@+id/delete_occasional_alarm_after_use"
                app:layout_constraintBottom_toTopOf="@+id/auto_silence_duration_layout" />

            <LinearLayout
                android:id="@+id/auto_silence_duration_layout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="2dp"
                android:paddingHorizontal="10dp"
                app:layout_constraintTop_toBottomOf="@id/space">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/auto_silence_duration_title"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_ringtone_off"
                    android:paddingStart="@null"
                    android:paddingEnd="10dp"
                    android:drawablePadding="10dp"
                    android:drawableTint="?attr/colorOnSurfaceVariant"
                    android:gravity="center_vertical"
                    android:focusable="true"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="@string/auto_silence_title" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/auto_silence_duration_value"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:focusable="true"
                    android:maxLines="1"
                    tools:text="5 min" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/snooze_duration_layout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="2dp"
                android:paddingHorizontal="10dp"
                app:layout_constraintTop_toBottomOf="@id/auto_silence_duration_layout">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/snooze_duration_title"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_snooze"
                    android:paddingStart="@null"
                    android:paddingEnd="10dp"
                    android:drawablePadding="10dp"
                    android:drawableTint="?attr/colorOnSurfaceVariant"
                    android:gravity="center_vertical"
                    android:focusable="true"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="@string/snooze_duration_title" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/snooze_duration_value"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:focusable="true"
                    android:maxLines="1"
                    tools:text="1 min" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/missed_alarm_repeat_limit_layout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="2dp"
                android:paddingHorizontal="10dp"
                app:layout_constraintTop_toBottomOf="@id/snooze_duration_layout">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/missed_alarm_repeat_limit_title"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_repeat"
                    android:paddingStart="@null"
                    android:paddingEnd="10dp"
                    android:drawablePadding="10dp"
                    android:gravity="center_vertical"
                    android:focusable="true"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="@string/missed_alarm_repeat_limit_title" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/missed_alarm_repeat_limit_value"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:focusable="true"
                    android:maxLines="1"
                    tools:text="3 times" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/crescendo_duration_layout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="2dp"
                android:paddingHorizontal="10dp"
                app:layout_constraintTop_toBottomOf="@id/missed_alarm_repeat_limit_layout">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/crescendo_duration_title"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_crescendo"
                    android:paddingStart="@null"
                    android:paddingEnd="10dp"
                    android:drawablePadding="10dp"
                    android:gravity="center_vertical"
                    android:focusable="true"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="@string/crescendo_duration_title" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/crescendo_duration_value"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:focusable="true"
                    android:maxLines="1"
                    tools:text="1 min" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/alarm_volume_layout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="2dp"
                android:paddingHorizontal="10dp"
                app:layout_constraintTop_toBottomOf="@id/crescendo_duration_layout">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/alarm_volume_title"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:paddingStart="@null"
                    android:paddingEnd="10dp"
                    android:drawablePadding="10dp"
                    android:drawableTint="?attr/colorOnSurfaceVariant"
                    android:gravity="center_vertical"
                    android:focusable="true"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="@string/alarm_volume_title"
                    tools:drawableStart="@drawable/ic_volume_up" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/alarm_volume_value"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:focusable="true"
                    android:maxLines="1"
                    tools:text="70%" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:backgroundTint="@color/colorAlert"
            android:text="@string/delete"
            android:textColor="?attr/colorOnError"
            android:textAllCaps="false"
            android:includeFontPadding="false"
            app:icon="@drawable/ic_delete"
            app:iconTint="?attr/colorOnError"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/duplicate"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constrainedWidth="true"
            tools:ignore="TextContrastCheck" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/duplicate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:backgroundTint="?attr/colorPrimary"
            android:text="@string/duplicate"
            android:textColor="?attr/colorSurfaceContainerLowest"
            android:textAllCaps="false"
            android:includeFontPadding="false"
            app:icon="@drawable/ic_duplicate"
            app:iconTint="?attr/colorSurfaceContainerLowest"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/delete"
            app:layout_constrainedWidth="true"
            tools:textStyle="bold" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>
