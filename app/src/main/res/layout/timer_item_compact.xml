<com.best.deskclock.timer.TimerItemCompact xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="12dp"
    tools:background="@drawable/bg_card_for_preview"
    tools:layout_marginHorizontal="10dp"
    tools:layout_marginBottom="2dp">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/timer_label"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="12dp"
        android:background="?attr/selectableItemBackground"
        android:drawablePadding="8dp"
        android:hint="@string/add_label"
        android:gravity="center_vertical"
        android:textSize="16sp"
        android:ellipsize="end"
        android:maxLines="1"
        android:focusable="true"
        android:drawableStart="@drawable/ic_label"
        android:drawableTint="?attr/colorOnSurfaceVariant"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/delete_timer_button"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="TextContrastCheck" />

    <View
        android:id="@+id/timer_indicator_state"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:background="@drawable/bg_circle_for_preview"
        tools:backgroundTint="#FF99CC00" />

    <ImageButton
        android:id="@+id/delete_timer_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="12dp"
        android:src="@drawable/ic_delete"
        android:scaleType="centerInside"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/delete"
        app:tint="?attr/colorPrimary"
        app:layout_constraintEnd_toStartOf="@+id/timer_indicator_state"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="TouchTargetSizeCheck" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/timer_controls_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/timer_label"
        app:layout_constraintBottom_toTopOf="@+id/timer_end_time">

        <com.best.deskclock.uicomponents.AutoSizingTextView
            android:id="@+id/timer_time_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="10dp"
            android:includeFontPadding="false"
            android:fontFeatureSettings="tnum"
            android:textSize="40sp"
            android:textAlignment="viewStart"
            android:textDirection="locale"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/reset_or_edit_button"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="01:23" />

        <com.google.android.material.button.MaterialButton
            style="?attr/materialIconButtonFilledStyle"
            android:id="@+id/reset_or_edit_button"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/reset"
            app:iconTint="?android:attr/colorBackground"
            app:iconGravity="textStart"
            app:materialSizeOverlay="@style/SizeOverlay.Material3Expressive.Button.IconButton.Small"
            app:layout_constraintEnd_toStartOf="@+id/timer_add_time_button"
            app:layout_constraintTop_toTopOf="@+id/play_pause_button"
            app:layout_constraintBottom_toBottomOf="@+id/play_pause_button"
            tools:icon="@drawable/ic_reset"
            tools:ignore="TouchTargetSizeCheck" />

        <com.google.android.material.button.MaterialButton
            style="?attr/materialButtonOutlinedStyle"
            android:id="@+id/timer_add_time_button"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_marginEnd="8dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:maxLines="1"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="16sp"
            android:textDirection="locale"
            app:strokeColor="?attr/colorOnSurfaceVariant"
            app:materialSizeOverlay="@style/SizeOverlay.Material3Expressive.Button.Small"
            app:layout_constraintEnd_toStartOf="@+id/play_pause_button"
            app:layout_constraintTop_toTopOf="@+id/play_pause_button"
            app:layout_constraintBottom_toBottomOf="@+id/play_pause_button"
            tools:text="+ 1:00"
            tools:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/play_pause_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:contentDescription="@string/timer_start"
            android:scaleType="centerInside"
            app:materialSizeOverlay="@style/SizeOverlay.Material3Expressive.Button.Small"
            app:iconTint="?android:attr/colorBackground"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:icon="@drawable/ic_fab_play" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/timer_end_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="6dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:gravity="end|center_vertical"
        android:ellipsize="end"
        android:maxLines="1"
        android:textStyle="italic"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/timer_controls_container"
        app:layout_constraintVertical_bias="0"
        tools:text="End time: 8:30 PM"
        tools:visibility="visible"
        tools:ignore="TextContrastCheck" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/linear_progress_indicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginHorizontal="12dp"
        android:max="1000"
        app:trackThickness="6dp"
        app:trackColor="?attr/colorPrimaryInverse"
        app:trackStopIndicatorSize="0dp"
        app:indicatorColor="?attr/colorSecondary"
        app:indicatorDirectionLinear="endToStart"
        app:layout_constraintTop_toBottomOf="@+id/timer_end_time"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_goneMarginTop="12dp"
        tools:progress="650" />

</com.best.deskclock.timer.TimerItemCompact>
