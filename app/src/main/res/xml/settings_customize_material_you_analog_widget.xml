<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="@string/style_category_title"
        app:allowDividerAbove="false"
        app:iconSpaceReserved="false">

        <ListPreference
            android:key="key_material_you_analog_widget_clock_dial"
            android:layout="@layout/settings_preference_layout"
            android:title="@string/clock_dial_title"
            android:entries="@array/clock_dial_material_entries"
            android:entryValues="@array/clock_dial_material_values"
            android:defaultValue="dial_sun"
            app:iconSpaceReserved="false"
            app:singleLineTitle="false" />

        <SwitchPreferenceCompat
            android:key="key_material_you_analog_widget_with_second_hand"
            android:layout="@layout/settings_preference_layout"
            android:title="@string/display_clock_seconds_pref"
            android:defaultValue="false"
            app:iconSpaceReserved="false"
            app:singleLineTitle="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="key_widget_color_category"
        android:title="@string/colors_category_title"
        app:allowDividerAbove="false"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:key="key_material_you_analog_widget_default_dial_color"
            android:layout="@layout/settings_preference_layout"
            android:title="@string/dial_default_color_title"
            android:defaultValue="true"
            app:iconSpaceReserved="false"
            app:singleLineTitle="false" />

        <com.best.deskclock.settings.custompreference.ColorPickerPreference
            android:key="key_material_you_analog_widget_custom_dial_color"
            android:layout="@layout/settings_preference_layout"
            android:title="@string/dial_color_title"
            android:defaultValue="#EEF0FF"
            app:iconSpaceReserved="false"
            app:singleLineTitle="false" />

        <SwitchPreferenceCompat
            android:key="key_material_you_analog_widget_default_hour_hand_color"
            android:layout="@layout/settings_preference_layout"
            android:title="@string/hour_hand_default_color_title"
            android:defaultValue="true"
            app:iconSpaceReserved="false"
            app:singleLineTitle="false" />

        <com.best.deskclock.settings.custompreference.ColorPickerPreference
            android:key="key_material_you_analog_widget_custom_hour_hand_color"
            android:layout="@layout/settings_preference_layout"
            android:title="@string/hour_hand_color_title"
            android:defaultValue="#575E71"
            app:iconSpaceReserved="false"
            app:singleLineTitle="false" />

        <SwitchPreferenceCompat
            android:key="key_material_you_analog_widget_default_minute_hand_color"
            android:layout="@layout/settings_preference_layout"
            android:title="@string/minute_hand_default_color_title"
            android:defaultValue="true"
            app:iconSpaceReserved="false"
            app:singleLineTitle="false" />

        <com.best.deskclock.settings.custompreference.ColorPickerPreference
            android:key="key_material_you_analog_widget_custom_minute_hand_color"
            android:layout="@layout/settings_preference_layout"
            android:title="@string/minute_hand_color_title"
            android:defaultValue="#475D92"
            app:iconSpaceReserved="false"
            app:singleLineTitle="false" />

        <SwitchPreferenceCompat
            android:key="key_material_you_analog_widget_default_second_hand_color"
            android:layout="@layout/settings_preference_layout"
            android:title="@string/second_hand_default_color_title"
            android:defaultValue="true"
            app:iconSpaceReserved="false"
            app:singleLineTitle="false" />

        <com.best.deskclock.settings.custompreference.ColorPickerPreference
            android:key="key_material_you_analog_widget_custom_second_hand_color"
            android:layout="@layout/settings_preference_layout"
            android:title="@string/second_hand_color_title"
            android:defaultValue="#725572"
            app:iconSpaceReserved="false"
            app:singleLineTitle="false" />

    </PreferenceCategory>

</PreferenceScreen>